{
    "name": "ordukaya-otomativ",
    "version": "1.0.0",
    "description": "Ordukaya Otomotiv Servis Otomasyonu",
    "main": "main.js",
    "author": "Efe Ali Ordukaya",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.ordukaya.otomasyon",
        "productName": "Ordukaya Otomasyon",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Ordukaya Otomasyon",
            "installerIcon": "icon.ico",
            "uninstallerIcon": "icon.ico"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "EfeAliORDUKAYA",
                "repo": "Ordukaya-Otomativ"
            }
        ]
    },
    "dependencies": {
        "electron-log": "^5.1.5",
        "electron-squirrel-startup": "^1.0.1",
        "electron-updater": "^6.8.9",
        "sqlite3": "^6.0.1",
        "sqlocal": "^0.18.0"
    },
    "devDependencies": {
        "electron": "^31.0.0",
        "electron-builder": "^24.13.3"
    }
}
